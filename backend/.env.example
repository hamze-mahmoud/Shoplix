# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/greenlight

# JWT secrets (use long random strings in production)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Server
PORT=3000
# Frontend origin (redirects after email verification) and backend base URL (email links)
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:3000

# Cloudinary (product/banner image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP account used to send verification emails
EMAIL_USER=
EMAIL_PASS=

# Social login (optional — buttons work once these are set)
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Optional: Redis cache (leave unset to run without cache)
# REDIS_URL=
