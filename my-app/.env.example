# Frontend build-time config (Vite). Copy to .env.local for local dev, or set
# these in the Vercel dashboard (Project → Settings → Environment Variables).

# Base URL of the API, WITH the /api suffix.
# Local dev leaves these blank → defaults to http://localhost:3000.
# Production: point at the deployed backend, e.g.
#   VITE_API_URL=https://shoplix-backend.onrender.com/api
#   VITE_SOCKET_URL=https://shoplix-backend.onrender.com
VITE_API_URL=
VITE_SOCKET_URL=

# Social login (optional — must match the backend GOOGLE_CLIENT_ID / FACEBOOK_APP_ID)
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
